# ──────────────────────────────────────────────────────────────
# Social Media Dist — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# The build will fail if the required Supabase vars are empty.

# Public app configuration
# Keep NEXT_PUBLIC_APP_URL aligned with the exact local or deployed origin
# and register <APP_URL>/auth/callback in Supabase Auth redirect URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── REQUIRED ── Auth will not work without these ─────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ── REQUIRED for server-side operations ──────────────────────
# Get this from: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ASSET_BUCKET=generated-assets

# AI draft generation
AI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# n8n webhook security
N8N_WEBHOOK_SHARED_SECRET=

# KIE image generation
KIE_API_KEY=
KIE_API_BASE_URL=https://api.kie.ai/api/v1
KIE_IMAGE_SUBMIT_PATH=/jobs/submit
KIE_IMAGE_RECORD_PATH=/jobs/record-info
KIE_IMAGE_DOWNLOAD_PATH=/jobs/download-url

# Publer publishing
PUBLER_API_KEY=
PUBLER_API_BASE_URL=https://app.publer.io/api/v1
PUBLER_POSTS_PATH=/posts
PUBLER_JOB_STATUS_TEMPLATE=https://app.publer.io/api/v1/job_status/{jobId}

# Google Sheets sync
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_DEFAULT_SHEET=Content Calendar
